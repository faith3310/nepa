{
    "compilerOptions": {
        "target": "ES2020",
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "jsx": "react-jsx",
        "allowJs": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "noFallthroughCasesInSwitch": true,
        "module": "Node16",
        "moduleResolution": "node16",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": false,
        "outDir": "./dist",
        "rootDir": "./",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@/controllers/*": [
                "./controllers/*"
            ],
            "@/services/*": [
                "./services/*"
            ],
            "@/middleware/*": [
                "./middleware/*"
            ],
            "@/types/*": [
                "./types/*"
            ],
            "@/utils/*": [
                "./utils/*"
            ],
            "@/config/*": [
                "./config/*"
            ]
        },
        "typeRoots": [
            "./node_modules/@types",
            "./types"
        ],
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        "types/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "**/*.test.ts",
        "**/*.spec.ts",
        "nepa-frontend",
        "nepa-dapp",
        "src/**/*",
        "microservices/**/*"
    ]
}
