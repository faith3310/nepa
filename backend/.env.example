# Database Per Service Configuration

# User Service Database
USER_SERVICE_DATABASE_URL="postgresql://user:password@localhost:5432/nepa_user_service?schema=public"

# Notification Service Database
NOTIFICATION_SERVICE_DATABASE_URL="postgresql://user:password@localhost:5433/nepa_notification_service?schema=public"

# Document Service Database
DOCUMENT_SERVICE_DATABASE_URL="postgresql://user:password@localhost:5434/nepa_document_service?schema=public"

# Utility Service Database
UTILITY_SERVICE_DATABASE_URL="postgresql://user:password@localhost:5435/nepa_utility_service?schema=public"

# Payment Service Database
PAYMENT_SERVICE_DATABASE_URL="postgresql://user:password@localhost:5436/nepa_payment_service?schema=public"

# Billing Service Database
BILLING_SERVICE_DATABASE_URL="postgresql://user:password@localhost:5437/nepa_billing_service?schema=public"

# Analytics Service Database
ANALYTICS_SERVICE_DATABASE_URL="postgresql://user:password@localhost:5438/nepa_analytics_service?schema=public"

# Webhook Service Database
WEBHOOK_SERVICE_DATABASE_URL="postgresql://user:password@localhost:5439/nepa_webhook_service?schema=public"

# Redis for caching and session management
REDIS_URL="redis://localhost:6379"

# Stellar Configuration
STELLAR_NETWORK="testnet"
STELLAR_HORIZON_URL="https://horizon-testnet.stellar.org"

# JWT Configuration
JWT_SECRET="your-secret-key-here"
JWT_EXPIRES_IN="24h"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Email Configuration
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASSWORD="your-password"

# AWS S3 Configuration
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="nepa-documents"

# IPFS Configuration
IPFS_HOST="ipfs.infura.io"
IPFS_PORT="5001"
IPFS_PROTOCOL="https"

# API Rate Limiting
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS="false"
RATE_LIMIT_SKIP_FAILED_REQUESTS="false"
RATE_LIMIT_SKIP_TOKEN_REQUESTS="true"

# Advanced Rate Limiting
PREMIUM_USER_RATE_LIMIT="1000"
ADMIN_USER_RATE_LIMIT="500"
STANDARD_USER_RATE_LIMIT="100"
GUEST_USER_RATE_LIMIT="20"

# Rate Limiting Headers
RATE_LIMIT_HEADERS_ENABLED="true"
RATE_LIMIT_RETRY_AFTER="true"

# Monitoring
SENTRY_DSN="your-sentry-dsn"
LOG_LEVEL="info"

# Redis Cache Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_DB=1
REDIS_KEY_PREFIX=nepa:cache:
REDIS_RETRY_DELAY=100
REDIS_MAX_RETRIES=3
REDIS_LAZY_CONNECT=true
REDIS_CLUSTER_ENABLED=false
REDIS_CLUSTER_NODES=[]

# Cache Strategy
CACHE_DEFAULT_TTL=3600
CACHE_MAX_MEMORY=536870912
CACHE_COMPRESSION_THRESHOLD=1024
CACHE_WARMUP_ENABLED=true
CACHE_MONITORING_ENABLED=true

# Cache Warmup
CACHE_WARMUP_INTERVAL=30
CACHE_WARMUP_BATCH_SIZE=50
CACHE_WARMUP_CONCURRENCY=5
CACHE_WARMUP_HIGH=true
CACHE_WARMUP_MEDIUM=true
CACHE_WARMUP_LOW=false

# Cache Monitoring & Alerts
CACHE_ALERT_HIT_RATE=0.7
CACHE_ALERT_RESPONSE_TIME=1000
CACHE_ALERT_MEMORY=536870912
CACHE_ALERT_ERROR_RATE=0.05
CACHE_METRICS_RETENTION=7
CACHE_ALERT_COOLDOWN=15
WEBHOOK_ALERT_URL=

# Cache Per-Service TTL (seconds)
CACHE_USER_TTL=3600
CACHE_PAYMENT_TTL=900
CACHE_BILLING_TTL=1800
CACHE_WEBHOOK_TTL=3600
CACHE_ANALYTICS_TTL=1800
CACHE_UTILITY_TTL=86400
CACHE_NOTIFICATION_TTL=3600
CACHE_DOCUMENT_TTL=7200

# Cache Per-Service Memory (bytes)
CACHE_USER_MEMORY=134217728
CACHE_PAYMENT_MEMORY=67108864
CACHE_BILLING_MEMORY=67108864
CACHE_WEBHOOK_MEMORY=33554432
CACHE_ANALYTICS_MEMORY=134217728
CACHE_UTILITY_MEMORY=16777216
CACHE_NOTIFICATION_MEMORY=33554432
CACHE_DOCUMENT_MEMORY=67108864

# Cache Performance
CACHE_COMPRESSION_ENABLED=true
CACHE_BATCH_SIZE=100
CACHE_MAX_CONCURRENCY=10
CACHE_RATE_LIMITING_ENABLED=true
CACHE_RATE_LIMIT=1000
CACHE_ENCRYPT_SENSITIVE=false
CACHE_ALLOWED_ORIGINS=*
